{
  "name": "speech_analysis",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "contexto": {
        "type": "string",
        "minLength": 10,
        "description": "Resumen corto de la llamada"
      },
      "account_id": {
        "anyOf": [{ "type": "string" }, { "type": "null" }],
        "description": "Número de cuenta del cliente si se menciona"
      },
      "product": {
        "anyOf": [{ "type": "string" }, { "type": "null" }],
        "description": "Producto al que se refiere la conversación"
      },
      "sentiment": {
        "anyOf": [
          { "type": "string", "enum": ["interesado", "neutral", "desinteresado"] },
          { "type": "null" }
        ]
      },
      "Titular": {
       "description": "Indicar si la persona que habla es el titular de la cuenta, no se sabe o no es el titular - No dejar en blanco o null",
       "anyOf": [
          { "type": "string", "enum": ["titular", "no_titular", "no_identificado"] },
          { "type": "null" }
        ]
      }
    },
    "required": ["contexto", "account_id", "product", "sentiment"],
    "additionalProperties": false
  }
}
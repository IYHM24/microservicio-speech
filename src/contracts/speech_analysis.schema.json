{
  "name": "speech_analysis",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "intent": {
        "type": "string",
        "description": "intento principal del cliente, como 'consulta de saldo', 'reclamo', 'solicitud de información', etc."
      },
      "account_id": {
        "anyOf": [{ "type": "string" }, { "type": "null" }],
        "description": "Número de cuenta del cliente si se menciona"
      },
      "product": {
        "anyOf": [{ "type": "string" }, { "type": "null" }],
        "description": "Producto al que se refiere la conversación"
      },
      "sentiment": {
        "anyOf": [
          { "type": "string", "enum": ["positivo", "neutral", "negativo"] },
          { "type": "null" }
        ]
      }
    },
    "required": ["intent", "account_id", "product", "sentiment"],
    "additionalProperties": false
  }
}